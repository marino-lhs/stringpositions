/* ═══════════════════════════════════════════════
   MUSIC THEORY DATA — POSITIONS
═══════════════════════════════════════════════ */
// For a given (instrument, position, string), the letter -> finger mapping.
const POSITIONS = {
  violin: {
    2: {
      G: { B: 1, C: 2, D: 3, E: 4 },
      D: { F: 1, G: 2, A: 3, B: 4 },
      A: { C: 1, D: 2, E: 3, F: 4 },
      E: { G: 1, A: 2, B: 3, C: 4 },
    },
    3: {
      G: { C: 1, D: 2, E: 3, F: 4 },
      D: { G: 1, A: 2, B: 3, C: 4 },
      A: { D: 1, E: 2, F: 3, G: 4 },
      E: { A: 1, B: 2, C: 3, D: 4 },
    },
    4: {
      G: { D: 1, E: 2, F: 3, G: 4 },
      D: { A: 1, B: 2, C: 3, D: 4 },
      A: { E: 1, F: 2, G: 3, A: 4 },
      E: { B: 1, C: 2, D: 3, E: 4 },
    },
  },
  viola: {
    2: {
      C: { E: 1, F: 2, G: 3, A: 4 },
      G: { B: 1, C: 2, D: 3, E: 4 },
      D: { F: 1, G: 2, A: 3, B: 4 },
      A: { C: 1, D: 2, E: 3, F: 4 },
    },
    3: {
      C: { F: 1, G: 2, A: 3, B: 4 },
      G: { C: 1, D: 2, E: 3, F: 4 },
      D: { G: 1, A: 2, B: 3, C: 4 },
      A: { D: 1, E: 2, F: 3, G: 4 },
    },
    4: {
      C: { G: 1, A: 2, B: 3, C: 4 },
      G: { D: 1, E: 2, F: 3, G: 4 },
      D: { A: 1, B: 2, C: 3, D: 4 },
      A: { E: 1, F: 2, G: 3, A: 4 },
    },
  },
};

const OPEN_STRINGS = {
  violin: { G: 55, D: 62, A: 69, E: 76 },
  viola:  { C: 48, G: 55, D: 62, A: 69 },
};

const STRING_ORDER = {
  violin: ['G', 'D', 'A', 'E'],
  viola:  ['C', 'G', 'D', 'A'],
};

const LETTER_SEMITONE = { C: 0, D: 2, E: 4, F: 5, G: 7, A: 9, B: 11 };

const INSTR = {
  violin: { name: 'Violin', clef: 'treble', desc: 'G · D · A · E  ·  Treble clef' },
  viola:  { name: 'Viola',  clef: 'alto',   desc: 'C · G · D · A  ·  Alto clef' },
};

/* ═══════════════════════════════════════════════
   MUSIC THEORY HELPERS
═══════════════════════════════════════════════ */
function noteToMidi(letter, accidental, octave) {
  return 12 * (octave + 1) + LETTER_SEMITONE[letter] + accidental;
}

function findNextLetterAbove(openMidi, letter) {
  for (let m = openMidi + 1; m < openMidi + 15; m++) {
    if (m % 12 === LETTER_SEMITONE[letter]) return m;
  }
  return null;
}

// For (instrument, position, letter, octave), figure out which string the note lives on.
function getStringForNote(instrument, position, letter, octave) {
  const positionMap = POSITIONS[instrument][position];
  const strings = STRING_ORDER[instrument];
  for (const str of strings) {
    const letterMap = positionMap[str];
    if (!letterMap || !(letter in letterMap)) continue;
    const finger1Letter = Object.keys(letterMap).find(k => letterMap[k] === 1);
    const finger4Letter = Object.keys(letterMap).find(k => letterMap[k] === 4);
    const openMidi = OPEN_STRINGS[instrument][str];
    const finger1Midi = findNextLetterAbove(openMidi, finger1Letter);
    const finger4Midi = findNextLetterAbove(openMidi, finger4Letter);
    const naturalMidi = noteToMidi(letter, 0, octave);
    if (naturalMidi >= finger1Midi && naturalMidi <= finger4Midi) {
      return str;
    }
  }
  return null;
}

function getFingerForNote(instrument, position, letter, octave) {
  const str = getStringForNote(instrument, position, letter, octave);
  if (!str) return null;
  return { string: str, finger: POSITIONS[instrument][position][str][letter] };
}

// All valid notes for a given instrument+position
function getValidNotesForPosition(instrument, position) {
  const positionMap = POSITIONS[instrument][position];
  const strings = STRING_ORDER[instrument];
  const result = [];
  for (const str of strings) {
    const letterMap = positionMap[str];
    const finger1Letter = Object.keys(letterMap).find(k => letterMap[k] === 1);
    const finger4Letter = Object.keys(letterMap).find(k => letterMap[k] === 4);
    const openMidi = OPEN_STRINGS[instrument][str];
    const finger1Midi = findNextLetterAbove(openMidi, finger1Letter);
    const finger4Midi = findNextLetterAbove(openMidi, finger4Letter);
    for (const letter of Object.keys(letterMap)) {
      for (let octave = 2; octave <= 7; octave++) {
        const naturalMidi = noteToMidi(letter, 0, octave);
        if (naturalMidi >= finger1Midi && naturalMidi <= finger4Midi) {
          result.push({ letter, octave, string: str, finger: letterMap[letter], naturalMidi });
        }
      }
    }
  }
  return result.sort((a, b) => a.naturalMidi - b.naturalMidi);
}

function ordinal(n) {
  if (n === 2) return '2nd';
  if (n === 3) return '3rd';
  return n + 'th';
}

function pickRandom(arr) {
  return arr[Math.floor(Math.random() * arr.length)];
}

/* ═══════════════════════════════════════════════
   VEXFLOW HELPERS
═══════════════════════════════════════════════ */
// Convert (letter, accidental, octave) to VexFlow key string like "c#/4"
function noteToVexKey(letter, accidental, octave) {
  const acc = accidental === 1 ? '#' : accidental === -1 ? 'b' : '';
  return `${letter.toLowerCase()}${acc}/${octave}`;
}

// Compute the "staff line position" for stem direction logic.
// For each clef, the middle line corresponds to a specific note.
//   Treble: middle line = B4
//   Alto:   middle line = C4
// Returns a number where 0 = middle line, positive = above, negative = below.
function staffPosition(clef, letter, octave) {
  const LETTERS = ['C','D','E','F','G','A','B'];
  const stepIdx = LETTERS.indexOf(letter);
  const totalSteps = octave * 7 + stepIdx;
  // middle line = B4 for treble (octave 4, B = idx 6) -> 4*7+6=34
  //               C4 for alto (octave 4, C = idx 0) -> 4*7+0=28
  const middleSteps = clef === 'treble' ? 34 : 28;
  return totalSteps - middleSteps;
}

// Apply user's stem direction rules:
//   - Above middle line: stem down
//   - Below middle line: stem up
//   - On middle line: default up unless majority are stem-down
function computeStemDirections(notes, clef) {
  const VF = Vex.Flow;
  // First pass: assign a tentative direction per note
  const tentative = notes.map(n => {
    const p = staffPosition(clef, n.letter, n.octave);
    if (p > 0) return VF.Stem.DOWN;
    if (p < 0) return VF.Stem.UP;
    return null; // on middle line, decide later
  });
  // Count above vs below decisions to decide middle-line notes (majority rule)
  const downCount = tentative.filter(d => d === VF.Stem.DOWN).length;
  const upCount = tentative.filter(d => d === VF.Stem.UP).length;
  const middleDir = downCount > upCount ? VF.Stem.DOWN : VF.Stem.UP;
  return tentative.map(d => d === null ? middleDir : d);
}

// Compute beam group ranges within a measure: each group is [startIdx, endIdx]
// (inclusive) where notes are eighths within the same beat. Singleton eighths
// (an eighth by itself in a beat) are NOT included — they get flags.
function computeBeamGroups(notes) {
  const groups = [];
  let runningBeat = 0;
  let curStart = -1;
  let curStartBeat = 0;
  for (let i = 0; i < notes.length; i++) {
    const isEighth = notes[i].duration === 'eighth';
    if (isEighth) {
      if (curStart === -1) {
        curStart = i;
        curStartBeat = runningBeat;
      } else if (Math.floor(runningBeat) !== Math.floor(curStartBeat)) {
        // Eighth in different beat — close previous group, start new
        if (i - 1 >= curStart + 1) groups.push([curStart, i - 1]);
        // (a singleton eighth becomes its own potential start; we'll re-evaluate)
        curStart = i;
        curStartBeat = runningBeat;
      }
    } else {
      if (curStart !== -1 && i - 1 >= curStart + 1) {
        groups.push([curStart, i - 1]);
      }
      curStart = -1;
    }
    runningBeat += DURATION_BEATS[notes[i].duration];
  }
  if (curStart !== -1 && notes.length - 1 >= curStart + 1) {
    groups.push([curStart, notes.length - 1]);
  }
  return groups;
}

// Compute stem directions, but FORCE all notes in a beam group to share direction.
// For a beam group, pick the direction based on the note furthest from the middle line
// (standard engraving convention). This avoids VexFlow's mixed-stem fallback to flags.
function computeStemDirectionsForMeasure(notes, clef) {
  const VF = Vex.Flow;
  const beamGroups = computeBeamGroups(notes);

  // Start with per-note tentative directions
  const dirs = notes.map(n => {
    const p = staffPosition(clef, n.letter, n.octave);
    if (p > 0) return VF.Stem.DOWN;
    if (p < 0) return VF.Stem.UP;
    return null;
  });

  // Resolve middle-line notes first using majority rule
  const downCount = dirs.filter(d => d === VF.Stem.DOWN).length;
  const upCount = dirs.filter(d => d === VF.Stem.UP).length;
  const middleDir = downCount > upCount ? VF.Stem.DOWN : VF.Stem.UP;
  for (let i = 0; i < dirs.length; i++) {
    if (dirs[i] === null) dirs[i] = middleDir;
  }

  // For each beam group, override to a single direction.
  // Pick direction based on the note furthest from middle line:
  //   if max-distance note is above middle -> all stems DOWN
  //   if max-distance note is below middle -> all stems UP
  //   tie -> stems UP (engraving convention favors up when in doubt)
  for (const [start, end] of beamGroups) {
    let maxDist = 0;
    let maxAbove = false; // tracks whether the extreme is above middle
    for (let i = start; i <= end; i++) {
      const p = staffPosition(clef, notes[i].letter, notes[i].octave);
      const dist = Math.abs(p);
      if (dist > maxDist) {
        maxDist = dist;
        maxAbove = p > 0;
      }
      // On tie, do NOT update — first-set direction wins, but we want UP on tie,
      // so we explicitly only flip to "above" when strictly greater.
    }
    const groupDir = maxAbove ? VF.Stem.DOWN : VF.Stem.UP;
    for (let i = start; i <= end; i++) dirs[i] = groupDir;
  }

  return { dirs, beamGroups };
}

// Convert duration token to VexFlow duration.
// q=quarter, 8=eighth, qd=dotted quarter, h=half
const DURATION_VEX = {
  'quarter': 'q',
  'eighth': '8',
  'dotted-quarter': 'q',  // dot added via addDotToAll() below
  'half': 'h',
};
const DURATION_BEATS = {
  'quarter': 1,
  'eighth': 0.5,
  'dotted-quarter': 1.5,
  'half': 2,
};

/* ═══════════════════════════════════════════════
   STAFF VIEW — SINGLE NOTE (Mode 1)
═══════════════════════════════════════════════ */
function SingleNoteStaff({ letter, octave, accidental, clef }) {
  const containerRef = useRef(null);

  useEffect(() => {
    if (!containerRef.current || typeof Vex === 'undefined' || !Vex.Flow) return;
    const VF = Vex.Flow;
    const el = containerRef.current;
    el.innerHTML = '';

    try {
      // Outer container is wider; the staff inside is smaller and centered.
      const W = 240, H = 180;
      const STAVE_W = 130; // narrower staff for tighter framing
      const STAVE_X = (W - STAVE_W) / 2;

      const renderer = new VF.Renderer(el, VF.Renderer.Backends.SVG);
      renderer.resize(W, H);
      const ctx = renderer.getContext();

      // Parchment background
      const svgEl = el.querySelector('svg');
      if (svgEl) {
        const bg = document.createElementNS('http://www.w3.org/2000/svg', 'rect');
        bg.setAttribute('x', '0');
        bg.setAttribute('y', '0');
        bg.setAttribute('width', String(W));
        bg.setAttribute('height', String(H));
        bg.setAttribute('fill', '#FBF7EE');
        bg.setAttribute('rx', '10');
        svgEl.insertBefore(bg, svgEl.firstChild);
      }

      const stave = new VF.Stave(STAVE_X, 60, STAVE_W);
      stave.addClef(clef);
      stave.setContext(ctx).draw();

      // Apply stem direction rule: above middle line = down, below = up, on = up by default
      const stemDir = computeStemDirections(
        [{ letter, octave }],
        clef
      )[0];

      const key = noteToVexKey(letter, accidental, octave);
      const note = new VF.StaveNote({
        clef,
        keys: [key],
        duration: 'q',
        stem_direction: stemDir,
      });
      if (accidental === 1) note.addAccidental(0, new VF.Accidental('#'));
      else if (accidental === -1) note.addAccidental(0, new VF.Accidental('b'));

      const voice = new VF.Voice({ num_beats: 1, beat_value: 4 });
      voice.setStrict(false);
      voice.addTickables([note]);

      // Format with smaller width so the note centers within the small stave
      new VF.Formatter().joinVoices([voice]).format([voice], STAVE_W - 50);
      voice.draw(ctx, stave);
    } catch (err) {
      console.error('VexFlow single-note render error:', err);
    }
  }, [letter, octave, accidental, clef]);

  return (
    <div ref={containerRef} style={{
      width: 240, height: 180, borderRadius: 10, overflow: 'hidden',
      background: '#FBF7EE', margin: '0 auto',
    }} />
  );
}

/* ═══════════════════════════════════════════════
   STAFF VIEW — PHRASE (Mode 2)
   Renders two measures using two adjacent VF.Stave objects.
═══════════════════════════════════════════════ */
function PhraseStaff({ phrase, clef, results }) {
  const containerRef = useRef(null);

  // Split phrase into two measures (each 4 beats)
  const splitPhraseIntoMeasures = (notes) => {
    const m1 = [], m2 = [];
    let beat = 0;
    for (const n of notes) {
      if (beat < 4) m1.push(n);
      else m2.push(n);
      beat += DURATION_BEATS[n.duration];
    }
    return [m1, m2];
  };

  const [m1, m2] = splitPhraseIntoMeasures(phrase);

  // Width sizing
  const m1Width = 100 + m1.length * 50; // clef + time sig + notes
  const m2Width = 30 + m2.length * 50;
  const W = m1Width + m2Width + 30;
  const H = 180;

  useEffect(() => {
    if (!containerRef.current || typeof Vex === 'undefined' || !Vex.Flow) return;
    const VF = Vex.Flow;
    const el = containerRef.current;
    el.innerHTML = '';

    try {
      const renderer = new VF.Renderer(el, VF.Renderer.Backends.SVG);
      renderer.resize(W, H);
      const ctx = renderer.getContext();

      // Parchment background
      const svgEl = el.querySelector('svg');
      if (svgEl) {
        const bg = document.createElementNS('http://www.w3.org/2000/svg', 'rect');
        bg.setAttribute('x', '0');
        bg.setAttribute('y', '0');
        bg.setAttribute('width', String(W));
        bg.setAttribute('height', String(H));
        bg.setAttribute('fill', '#FBF7EE');
        bg.setAttribute('rx', '10');
        svgEl.insertBefore(bg, svgEl.firstChild);
      }

      // Helper to make VF notes for a given measure slice
      const makeVfNotes = (notesSlice, stemSlice, indexOffset) => {
        return notesSlice.map((n, idx) => {
          const key = noteToVexKey(n.letter, n.accidental, n.octave);
          const note = new VF.StaveNote({
            clef,
            keys: [key],
            duration: DURATION_VEX[n.duration],
            stem_direction: stemSlice[idx],
          });
          if (n.duration === 'dotted-quarter') {
            note.addDotToAll();
          }
          if (n.accidental === 1) note.addAccidental(0, new VF.Accidental('#'));
          else if (n.accidental === -1) note.addAccidental(0, new VF.Accidental('b'));
          if (results) {
            const color = results[indexOffset + idx] ? '#15803d' : '#b91c1c';
            note.setStyle({ fillStyle: color, strokeStyle: color });
          }
          return note;
        });
      };

      // Compute stem directions and beam groups PER MEASURE
      // (this ensures middle-line majority rule applies per measure, and beam
      // groups force uniform stem direction within them)
      const m1Result = computeStemDirectionsForMeasure(m1, clef);
      const m2Result = computeStemDirectionsForMeasure(m2, clef);

      const stave1 = new VF.Stave(10, 50, m1Width);
      stave1.addClef(clef);
      stave1.addTimeSignature('4/4');
      stave1.setContext(ctx).draw();

      const stave2 = new VF.Stave(10 + m1Width, 50, m2Width + 10);
      stave2.setContext(ctx).draw();

      const vfM1 = makeVfNotes(m1, m1Result.dirs, 0);
      const vfM2 = makeVfNotes(m2, m2Result.dirs, m1.length);

      const beats1 = m1.reduce((s, n) => s + DURATION_BEATS[n.duration], 0);
      const beats2 = m2.reduce((s, n) => s + DURATION_BEATS[n.duration], 0);

      const voice1 = new VF.Voice({ num_beats: Math.round(beats1), beat_value: 4 });
      voice1.setStrict(false);
      voice1.addTickables(vfM1);

      const voice2 = new VF.Voice({ num_beats: Math.round(beats2), beat_value: 4 });
      voice2.setStrict(false);
      voice2.addTickables(vfM2);

      // Format each voice independently within its stave
      new VF.Formatter().joinVoices([voice1]).format([voice1], m1Width - 100);
      new VF.Formatter().joinVoices([voice2]).format([voice2], m2Width - 30);

      // Build beams BEFORE drawing the voices — Beam constructor marks each
      // note as beamed, which suppresses the individual flag glyphs.
      const beams1 = m1Result.beamGroups.map(([s, e]) => new VF.Beam(vfM1.slice(s, e + 1)));
      const beams2 = m2Result.beamGroups.map(([s, e]) => new VF.Beam(vfM2.slice(s, e + 1)));

      voice1.draw(ctx, stave1);
      voice2.draw(ctx, stave2);

      beams1.forEach(b => b.setContext(ctx).draw());
      beams2.forEach(b => b.setContext(ctx).draw());
    } catch (err) {
      console.error('VexFlow phrase render error:', err);
    }
  }, [phrase, clef, results]);

  return (
    <div ref={containerRef} style={{
      width: W, height: H, borderRadius: 10, overflow: 'hidden',
      background: '#FBF7EE', margin: '0 auto',
    }} />
  );
}

/* ═══════════════════════════════════════════════
   FINGER NUMBER ROW
═══════════════════════════════════════════════ */
function FingerRow({ onClick, selected, correct, showResult, disabled }) {
  // A row of 4 circular buttons numbered 1-4
  const fingers = [1, 2, 3, 4];
  return (
    <div style={{ display: 'flex', gap: 16, justifyContent: 'center', marginTop: 8 }}>
      {fingers.map(f => {
        let className = 'finger-btn';
        if (showResult) {
          if (f === correct) className += ' correct';
          else if (f === selected && f !== correct) className += ' wrong';
        } else if (selected === f) {
          className += ' active';
        }
        return (
          <button
            key={f}
            className={className}
            disabled={disabled}
            onClick={() => onClick(f)}
            style={{
              width: 56, height: 56, borderRadius: '50%',
              fontSize: 22, lineHeight: 1,
            }}
          >
            {f}
          </button>
        );
      })}
    </div>
  );
}

/* ═══════════════════════════════════════════════
   PRE-COMPOSED PHRASES
