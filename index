/* ═══════════════════════════════════════════════
   QUESTION GENERATION (MODE 1)
═══════════════════════════════════════════════ */
function generateSingleNoteQuestion(instrument, position) {
  const validNotes = getValidNotesForPosition(instrument, position);
  const note = pickRandom(validNotes);
  return {
    letter: note.letter,
    accidental: 0,
    octave: note.octave,
    correctString: note.string,
    correctFinger: note.finger,
    position,
  };
}

