/* ═══════════════════════════════════════════════
   SCREEN: MODE 1 — SINGLE NOTE
═══════════════════════════════════════════════ */
function Mode1Screen({ instrument, positionMode, onBack }) {
  const clef = INSTR[instrument].clef;

  // Determine which position to use for each question
  const pickPosition = useCallback(() => {
    if (positionMode === 'all') return pickRandom([2, 3, 4]);
    return positionMode;
  }, [positionMode]);

  const [question, setQuestion] = useState(() =>
    generateSingleNoteQuestion(instrument, pickPosition())
  );
  const [selected, setSelected] = useState(null);
  const [showResult, setShowResult] = useState(false);
  const [score, setScore] = useState({ correct: 0, total: 0 });

  const onFinger = (f) => {
    if (showResult) return;
    setSelected(f);
    setShowResult(true);
    setScore(s => ({
      correct: s.correct + (f === question.correctFinger ? 1 : 0),
      total: s.total + 1,
    }));
  };

  const next = () => {
    setQuestion(generateSingleNoteQuestion(instrument, pickPosition()));
    setSelected(null);
    setShowResult(false);
  };

  const isCorrect = selected === question.correctFinger;

  return (
    <div style={{
      minHeight: '100vh', padding: '24px 20px', background: '#0c1220', position: 'relative',
    }}>
      <style>{CSS}</style>
      <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', marginBottom: 20, maxWidth: 700, margin: '0 auto 20px' }}>
        <button className="ghost-btn" onClick={onBack}>← Home</button>
        <div style={{ color: '#6b7280', fontSize: 14 }}>
          Score: <span style={{ color: '#f1ece2', fontWeight: 600 }}>{score.correct} / {score.total}</span>
        </div>
      </div>

      <div style={{ maxWidth: 600, margin: '0 auto', textAlign: 'center' }}>
        <div style={{
          color: '#c89b3c', fontSize: 12, letterSpacing: 3,
          textTransform: 'uppercase', marginBottom: 6,
        }}>{INSTR[instrument].name}</div>
        <div style={{
          fontFamily: "'Playfair Display',serif",
          fontSize: 28, fontWeight: 700, color: '#f1ece2', marginBottom: 24,
        }}>{ordinal(question.position)} Position</div>

        <SingleNoteStaff
          letter={question.letter}
          accidental={question.accidental}
          octave={question.octave}
          clef={clef}
        />

        <div style={{ color: '#6b7280', fontSize: 13, marginTop: 18, marginBottom: 4 }}>
          Which finger?
        </div>

        <FingerRow
          onClick={onFinger}
          selected={selected}
          correct={question.correctFinger}
          showResult={showResult}
          disabled={showResult}
        />

        {showResult && (
          <div className="slide" style={{
            marginTop: 24, padding: 16, borderRadius: 10,
            background: isCorrect ? 'rgba(34,197,94,0.15)' : 'rgba(239,68,68,0.15)',
            border: `1px solid ${isCorrect ? '#22c55e' : '#ef4444'}`,
            color: '#f1ece2', maxWidth: 460, margin: '24px auto 0',
          }}>
            <div style={{ fontWeight: 600, marginBottom: isCorrect ? 0 : 6 }}>
              {isCorrect ? 'Correct!' : 'Not quite.'}
            </div>
            {!isCorrect && (
              <div style={{ fontSize: 14, color: '#cbd5e1', lineHeight: 1.5 }}>
                {question.letter}{question.octave} in {ordinal(question.position)} position is
                on the <strong style={{ color: '#c89b3c' }}>{question.correctString} string</strong>,
                played with finger <strong style={{ color: '#c89b3c' }}>{question.correctFinger}</strong>.
              </div>
            )}
            <button className="primary-btn" onClick={next} style={{ marginTop: 14 }}>
              Next note →
            </button>
          </div>
        )}
      </div>
    </div>
  );
}

/* ═══════════════════════════════════════════════
   SCREEN: MODE 2 — PHRASE
═══════════════════════════════════════════════ */
function Mode2Screen({ instrument, positionMode, onBack }) {
  const clef = INSTR[instrument].clef;
  const [level, setLevel] = useState(1);

  // Pick the position for each phrase. For "all", randomize per phrase.
  const pickPosition = useCallback(() => {
    if (positionMode === 'all') return pickRandom([2, 3, 4]);
    return positionMode;
  }, [positionMode]);

  // Pick a random phrase from the chosen position+level
  const generatePhrase = useCallback(() => {
    const position = pickPosition();
    const phrasesAtLevel = PHRASES[instrument][position][level];
    const phrase = pickRandom(phrasesAtLevel);
    return { phrase, position };
  }, [instrument, level, pickPosition]);

  const [current, setCurrent] = useState(() => generatePhrase());
  const [fingerInputs, setFingerInputs] = useState(() => new Array(current.phrase.length).fill(null));
  const [activeIndex, setActiveIndex] = useState(0);
  const [results, setResults] = useState(null);
  const [score, setScore] = useState({ correct: 0, total: 0 });

  // When level changes, generate a new phrase
  useEffect(() => {
    const gen = generatePhrase();
    setCurrent(gen);
    setFingerInputs(new Array(gen.phrase.length).fill(null));
    setActiveIndex(0);
    setResults(null);
  }, [level, generatePhrase]);

  // Keyboard input
  useEffect(() => {
    const handleKey = (e) => {
      if (results) return;
      if (['1','2','3','4'].includes(e.key)) {
        e.preventDefault();
        enterFinger(parseInt(e.key));
      } else if (e.key === 'Backspace' || e.key === 'ArrowLeft') {
        e.preventDefault();
        setActiveIndex(i => Math.max(0, i - 1));
      } else if (e.key === 'ArrowRight') {
        e.preventDefault();
        setActiveIndex(i => Math.min(current.phrase.length - 1, i + 1));
      } else if (e.key === 'Enter' && fingerInputs.every(f => f !== null) && !results) {
        e.preventDefault();
        handleSubmit();
      }
    };
    window.addEventListener('keydown', handleKey);
    return () => window.removeEventListener('keydown', handleKey);
  });

  const enterFinger = (f) => {
    if (results) return;
    setFingerInputs(prev => {
      const next = [...prev];
      next[activeIndex] = f;
      return next;
    });
    setActiveIndex(i => Math.min(current.phrase.length - 1, i + 1));
  };

  const handleSubmit = () => {
    const newResults = current.phrase.map((n, i) => {
      const r = getFingerForNote(instrument, current.position, n.letter, n.octave);
      return r && fingerInputs[i] === r.finger;
    });
    setResults(newResults);
    setScore(s => ({
      correct: s.correct + newResults.filter(r => r).length,
      total: s.total + current.phrase.length,
    }));
  };

  const handleNextPhrase = () => {
    const gen = generatePhrase();
    setCurrent(gen);
    setFingerInputs(new Array(gen.phrase.length).fill(null));
    setActiveIndex(0);
    setResults(null);
  };

  const allFilled = fingerInputs.every(f => f !== null);

  return (
    <div style={{
      minHeight: '100vh', padding: '24px 20px', background: '#0c1220', position: 'relative',
    }}>
      <style>{CSS}</style>
      <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', marginBottom: 20, maxWidth: 900, margin: '0 auto 20px' }}>
        <button className="ghost-btn" onClick={onBack}>← Home</button>
        <div style={{ color: '#6b7280', fontSize: 14 }}>
          Score: <span style={{ color: '#f1ece2', fontWeight: 600 }}>{score.correct} / {score.total}</span>
        </div>
      </div>

      <div style={{ maxWidth: 900, margin: '0 auto', textAlign: 'center' }}>
        <div style={{
          color: '#c89b3c', fontSize: 12, letterSpacing: 3,
          textTransform: 'uppercase', marginBottom: 6,
        }}>{INSTR[instrument].name}</div>
        <div style={{
          fontFamily: "'Playfair Display',serif",
          fontSize: 26, fontWeight: 700, color: '#f1ece2', marginBottom: 14,
        }}>{ordinal(current.position)} Position</div>

        {/* Level selector */}
        <div style={{ display: 'flex', justifyContent: 'center', gap: 8, marginBottom: 20, flexWrap: 'wrap' }}>
          {[1, 2, 3, 4].map(lv => (
            <button
              key={lv}
              onClick={() => setLevel(lv)}
              style={{
                padding: '6px 14px', borderRadius: 6,
                background: level === lv ? '#c89b3c' : 'transparent',
                color: level === lv ? '#0c1220' : '#6b7280',
                border: `1px solid ${level === lv ? '#c89b3c' : '#253348'}`,
                fontFamily: "'DM Sans',sans-serif", fontSize: 13, fontWeight: 600,
                cursor: 'pointer',
              }}
            >
              Level {lv}: {LEVEL_NAMES[lv]}
            </button>
          ))}
        </div>

        {/* Staff */}
        <div style={{ overflowX: 'auto', marginBottom: 20 }}>
          <PhraseStaff
            phrase={current.phrase}
            clef={clef}
            results={results}
          />
        </div>

        {/* Finger entry boxes (showing what the user has entered) */}
        <div style={{
          display: 'flex', gap: 8, justifyContent: 'center', flexWrap: 'wrap',
          marginBottom: 14,
        }}>
          {current.phrase.map((n, i) => {
            const isActive = !results && activeIndex === i;
            const r = results?.[i];
            return (
              <button
                key={i}
                onClick={() => !results && setActiveIndex(i)}
                disabled={!!results}
                style={{
                  width: 36, height: 36, borderRadius: 6,
                  background: r === true ? 'rgba(34,197,94,0.25)' : r === false ? 'rgba(239,68,68,0.25)' : isActive ? '#fde68a' : '#fbf7ee',
                  border: isActive ? '2px solid #c89b3c' : '1px solid #8896aa',
                  color: '#222', fontWeight: 700, fontSize: 16,
                  cursor: results ? 'default' : 'pointer',
                  fontFamily: "'DM Sans',sans-serif",
                }}
              >
                {fingerInputs[i] !== null ? fingerInputs[i] : ''}
              </button>
            );
          })}
        </div>

        {/* Number row buttons */}
        <FingerRow
          onClick={enterFinger}
          selected={null}
          correct={null}
          showResult={false}
          disabled={!!results}
        />

        <div style={{ color: '#6b7280', fontSize: 12, marginTop: 12 }}>
          Click numbers to fill, or use keys 1-4 · Backspace/← to go back · Enter to submit
        </div>

        {/* Submit / Next */}
        <div style={{ marginTop: 18 }}>
          {!results && (
            <button
              className="primary-btn"
              onClick={handleSubmit}
              disabled={!allFilled}
            >Submit</button>
          )}
          {results && (
            <div className="slide" style={{
              padding: 16, borderRadius: 10,
              background: '#162032', border: '1px solid #253348',
              color: '#f1ece2', maxWidth: 600, margin: '0 auto',
            }}>
              <div style={{ fontWeight: 600, marginBottom: 8, fontSize: 16 }}>
                {results.filter(r => r).length} of {current.phrase.length} correct
              </div>
              {results.some(r => !r) && (
                <div style={{ fontSize: 13, color: '#cbd5e1', marginBottom: 12, lineHeight: 1.7 }}>
                  Correct fingerings:&nbsp;
                  {current.phrase.map((n, i) => {
                    const r = getFingerForNote(instrument, current.position, n.letter, n.octave);
                    return (
                      <span key={i} style={{
                        marginRight: 10,
                        color: results[i] ? '#22c55e' : '#ef4444',
                        fontFamily: 'monospace',
                      }}>
                        {n.letter}{n.octave}={r?.finger}
                        <span style={{ color: '#6b7280', fontSize: 11 }}>({r?.string})</span>
                      </span>
                    );
                  })}
                </div>
              )}
              <button className="primary-btn" onClick={handleNextPhrase}>Next phrase →</button>
            </div>
          )}
        </div>
      </div>
    </div>
  );
}

/* ═══════════════════════════════════════════════
   APP ROOT
═══════════════════════════════════════════════ */
function App() {
  const [screen, setScreen] = useState('home');
  const [instrument, setInstrument] = useState('violin');
  const [positionMode, setPositionMode] = useState(3);

  if (screen === 'mode1') {
    return <Mode1Screen instrument={instrument} positionMode={positionMode} onBack={() => setScreen('home')} />;
  }
  if (screen === 'mode2') {
    return <Mode2Screen instrument={instrument} positionMode={positionMode} onBack={() => setScreen('home')} />;
  }
  return (
    <HomeScreen
      instrument={instrument}
      setInstrument={setInstrument}
      positionMode={positionMode}
      setPositionMode={setPositionMode}
      onStartMode1={() => setScreen('mode1')}
      onStartMode2={() => setScreen('mode2')}
    />
  );
}

const root = ReactDOM.createRoot(document.getElementById('root'));
root.render(<App />);
  </script>
</body>
